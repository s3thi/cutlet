# Cutlet clang-tidy configuration.
# Conservative rule set: catch real bugs, avoid noisy false positives.
# Run: make lint

Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  portability-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-signal-handler,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -misc-include-cleaner,
  -misc-unused-parameters,
  -misc-no-recursion,

# Only show warnings from project headers, not system headers.
HeaderFilterRegex: 'src/.*\.h$'


WarningsAsErrors: '*'
