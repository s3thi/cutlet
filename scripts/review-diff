#!/bin/sh
# review-diff — produce a diff and file list for code review.
#
# Usage:
#   review-diff                     # staged + unstaged changes (default)
#   review-diff working             # same as above
#   review-diff branch <name>       # diff from main...<name>
#   review-diff merge               # most recent merge commit
#   review-diff last <N>            # last N commits
#   review-diff files <f1> [f2..]   # list specific files (no diff, just paths)
#
# Output:
#   Section 1: "## Changed files" — one path per line (src/ and tests/ only)
#   Section 2: "## Diff" — the unified diff (omitted in "files" mode)
#
# Only includes .c and .h files under src/ and tests/.

set -e

MAIN_BRANCH="main"
FILE_FILTER='\.([ch])$'

filter_files() {
    grep -E "^(src|tests)/" | grep -E "$FILE_FILTER" || true
}

mode="${1:-working}"
shift 2>/dev/null || true

case "$mode" in
    working)
        # Staged + unstaged changes vs HEAD
        diff_output=$(git diff HEAD -- src/ tests/ || true)
        files=$(git diff --name-only HEAD -- src/ tests/ | filter_files)
        ;;
    branch)
        branch_name="${1:?Usage: review-diff branch <name>}"
        # Three-dot diff: changes on branch since it diverged from main
        diff_output=$(git diff "${MAIN_BRANCH}...${branch_name}" -- src/ tests/ || true)
        files=$(git diff --name-only "${MAIN_BRANCH}...${branch_name}" -- src/ tests/ | filter_files)
        ;;
    merge)
        # Find the most recent merge commit
        merge_sha=$(git log --merges -1 --format="%H")
        if [ -z "$merge_sha" ]; then
            echo "Error: no merge commits found" >&2
            exit 1
        fi
        # Diff between the merge commit's first parent and the merge itself
        diff_output=$(git diff "${merge_sha}^1..${merge_sha}" -- src/ tests/ || true)
        files=$(git diff --name-only "${merge_sha}^1..${merge_sha}" -- src/ tests/ | filter_files)
        echo "## Merge commit"
        echo ""
        git log -1 --format="  %H %s" "$merge_sha"
        echo ""
        ;;
    last)
        count="${1:?Usage: review-diff last <N>}"
        diff_output=$(git diff "HEAD~${count}..HEAD" -- src/ tests/ || true)
        files=$(git diff --name-only "HEAD~${count}..HEAD" -- src/ tests/ | filter_files)
        echo "## Commits"
        echo ""
        git log --oneline -"${count}"
        echo ""
        ;;
    files)
        if [ $# -eq 0 ]; then
            echo "Usage: review-diff files <file1> [file2...]" >&2
            exit 1
        fi
        echo "## Changed files"
        echo ""
        for f in "$@"; do
            echo "$f"
        done
        # No diff section in files mode — the reviewer reads full files
        exit 0
        ;;
    *)
        echo "Unknown mode: $mode" >&2
        echo "Usage: review-diff [working|branch <name>|merge|last <N>|files <f1>...]" >&2
        exit 1
        ;;
esac

echo "## Changed files"
echo ""
if [ -z "$files" ]; then
    echo "(no C/H files changed)"
else
    echo "$files"
fi
echo ""
echo "## Diff"
echo ""
if [ -z "$diff_output" ]; then
    echo "(no diff)"
else
    echo "$diff_output"
fi
